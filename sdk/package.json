{
  "name": "@clawkernel/sdk",
  "version": "0.3.0",
  "description": "Zero-dependency TypeScript SDK for building CKP-conformant agents (L1/L2/L3)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:dev": "tsc -p tsconfig.json && node scripts/postbuild-dev.mjs",
    "lint": "eslint \"src/**/*.ts\" \"examples/**/*.ts\" \"test/**/*.mjs\"",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\" \"test/**/*.mjs\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"examples/**/*.ts\" \"test/**/*.mjs\" \"*.json\" \"*.md\"",
    "test": "npm run build && node --test --test-force-exit test/*.mjs",
    "clean": "rm -rf dist"
  },
  "author": "Angel Galvis Caballero <angel@datastrat.co>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelgalvisc/clawkernel.git",
    "directory": "sdk"
  },
  "keywords": [
    "ckp",
    "clawkernel",
    "agent",
    "ai-agent",
    "json-rpc",
    "protocol",
    "sdk",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "homepage": "https://www.clawkernel.com/"
}
